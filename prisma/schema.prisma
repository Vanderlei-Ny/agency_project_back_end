generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  SUPERADMIN
  AGENCY_ADMIN
  AGENCY_MEMBER
  CLIENT
}

enum FormStatus {
  PENDING_BUDGET
  BUDGET_SENT
  APPROVED
  REJECTED
  IN_PROGRESS
  DELIVERED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(CLIENT)
  agencyId     String?
  agency       Agency?  @relation(fields: [agencyId], references: [id])
  forms        Form[]
  formResponses Form[]  @relation("FormResponses")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Agency {
  id            String    @id @default(uuid())
  name          String
  description   String?
  phone         String?
  statusAgency  Boolean   @default(true)
  numberOfStars Float     @default(0)
  iconAgency    String?
  users         User[]
  forms         Form[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
}

model Form {
  id              String     @id @default(uuid())
  description     String
  clientId        String
  client          User       @relation(fields: [clientId], references: [id])
  agencyId        String
  agency          Agency     @relation(fields: [agencyId], references: [id])
  respondedByUserId String?
  respondedByUser User?      @relation("FormResponses", fields: [respondedByUserId], references: [id])
  respondedAt     DateTime?
  budgetValue     String?
  budgetMessage   String?
  paymentMethod   String?
  rejectionReason String?
  agencyFeedback  String?
  deliveryStoredName String?
  deliveryFileName   String?
  deliveryMimeType   String?
  deliveryMessage    String?
  colors          Color[]
  status          FormStatus @default(PENDING_BUDGET)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
}

model Color {
  id        String   @id @default(uuid())
  name      String
  hexCode   String
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
